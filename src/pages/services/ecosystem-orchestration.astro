---
// =============================================================================
// SERVICE PAGE — DEP.03 Ecosystem Orchestration
// =============================================================================
// Built from src/pages/services/enterprise-ai-integration.astro (the template).
// Source copy: cap-service-ecosystem-orchestration.md.
// =============================================================================
import Layout from '@/layouts/Layout.astro';
import Footer from '@/components/Footer.astro';

const code = 'DEP.03';
const kicker = 'What We Deploy';
const title = 'Ecosystem Orchestration';
const tagline = 'The tools you already pay for, finally talking to each other.';
const subhead =
  'We wire your stack — CRM, accounting, email, scheduling, billing, ticketing — through Make.com and n8n, so a single trigger fires the right task in the right tool with no human in the middle.';

const partners = [
  'Make.com',
  'n8n',
  'Supabase',
  'Stripe',
  'Calendly',
  'HubSpot',
  'QuickBooks',
  'ActiveCampaign'
];

const symptoms = [
  'A new customer signed today shows up in your CRM, your accounting system, and your email platform — because three people on the team typed the same name into three different boxes.',
  "You can name two SaaS tools you pay for that nobody on the team actually uses, because they were bought to solve a sync problem and didn't.",
  'Reconciling Stripe charges to invoices to CRM stages happens once a week, by hand, by somebody who would rather not.',
  'When a teammate is out, two or three workflows quietly stop. Nobody finds out for a week.'
];

const deliverables = [
  {
    n: '01',
    title: 'A map of the current chaos.',
    body:
      "Every tool in your stack, every handoff between them, every place a human is currently the integration. Drawn on one page. You'll recognize patterns you didn't know were patterns. We share it on day three."
  },
  {
    n: '02',
    title: 'Production scenarios in Make.com or n8n, deployed under your accounts.',
    body:
      'Built modularly, named clearly, version-controlled. Errors get caught, retried, and routed to a Slack channel a human watches. Nothing fails silently. You inherit working credentials and the ops dashboard.'
  },
  {
    n: '03',
    title: 'A unified webhook and event layer.',
    body:
      "Inbound triggers — Stripe, Calendly, form submissions, inbound email, vendor APIs — land in one place, get logged, then route to the right downstream tool. If you ever swap a vendor, the rest of the stack doesn't know the difference."
  },
  {
    n: '04',
    title: 'Two-way sync between your records of truth.',
    body:
      'CRM ↔ database, accounting ↔ CRM, email platform ↔ CRM. Conflict resolution rules written down and approved before we ship. We do not pretend two-way sync is easy. We make it explicit.'
  },
  {
    n: '05',
    title: 'A kill switch and a shadow mode.',
    body:
      'Every scenario can run in shadow mode for a week before it touches production. Every scenario has a one-click pause. If a vendor outage takes down a downstream system, the upstream side queues instead of losing work.'
  },
  {
    n: '06',
    title: 'A runbook and an ops cadence.',
    body:
      'Written documentation for every flow, an alert routing scheme that a non-engineer can read, and an optional weekly review where we look at the logs together. The system is staffable by your team, not by us.'
  }
];

const process = [
  {
    week: 'Week 0',
    label: 'Diagnose',
    body:
      'We shadow the people who are currently the integration. We map every tool, every trigger, every copy-paste loop. We come back with the chaos map and the priority list.'
  },
  {
    week: 'Week 1',
    label: 'Architect',
    body:
      'We design the event layer, pick Make.com or n8n per scenario (it is rarely either-or), and write down the conflict resolution rules. Sign-off in writing before we build.'
  },
  {
    week: 'Weeks 2–3',
    label: 'Build',
    body:
      'We stand up the scenarios in your accounts. Modular, named, logged. Internal tests run continuously. You see the dashboard from day one.'
  },
  {
    week: 'Week 4',
    label: 'Shadow mode',
    body:
      'Every scenario runs against live events but writes to a sandbox or a "would have done X" log. We compare against what humans actually did. We tune until the diff is zero.'
  },
  {
    week: 'Week 5',
    label: 'Cut over',
    body:
      'Production scenarios go live in priority order. The kill switch is one click. Daily standups during cutover week.'
  },
  {
    week: 'Week 6+',
    label: 'Care',
    body:
      'Optional retainer. We watch the alerts, fix the breakages, add new scenarios as the business grows. Or we hand over the runbook and disappear.'
  }
];

const caseStudies = [
  {
    code: 'CS.02',
    title: 'Brokerage pipeline fed straight into ledger and reporting.',
    impact: '+1,800 hrs/yr returned to producers',
    sector: 'Real Estate',
    href: '/case-studies/brokerage-pipeline'
  },
  {
    code: 'CS.03',
    title: 'Field RFIs to office approvals in a single rhythm.',
    impact: '−41% rework on submittals',
    sector: 'Construction',
    href: '/case-studies/field-to-office'
  }
];

const faqs = [
  {
    q: 'We already have Zapier. Why Make.com or n8n?',
    a: "Zapier is fine for a handful of one-step automations and a team that doesn't want to learn anything new. Make.com is what we reach for when scenarios get past three steps, need branching logic, or need a real audit log — and it's about a third the price at scale. n8n is what we deploy when the team needs to self-host or wants the open-source guarantee. We've inherited Zapier setups, kept them where they were working, and only ported the pieces that had outgrown it. We don't rebuild for the sake of rebuilding."
  },
  {
    q: "How do we know an automation isn't quietly failing?",
    a: "Every scenario logs to a dashboard with status, payload, and latency. Errors route to a Slack channel a human watches. We set thresholds — 'if more than 3 retries in an hour, page somebody' — at build time and tune them at week six. The system is built to tell on itself. We've never lost a customer because a scenario failed silently. We've lost a few minutes because somebody had to look at the dashboard."
  },
  {
    q: 'Where does our data go?',
    a: "Through Make.com or n8n's execution engines, which sit in the EU or US depending on which we pick at setup. Both vendors offer enterprise terms with data residency commitments. n8n self-hosted runs on your infrastructure and never leaves it. Inbound webhooks and outbound API calls carry your data through these engines for the seconds it takes to process. We don't store payloads ourselves. The vendor's logs retain by your plan settings — typically 7 to 30 days."
  },
  {
    q: 'How long until something works?',
    a: "The first scenario goes live in week two. Most clients see their worst copy-paste loop disappear by week three. Full cutover is week five or six depending on scope. If we can't kill the worst loop in three weeks, we owe you an explanation in writing."
  },
  {
    q: 'What does this cost?',
    a: "A typical engagement is $20K to $60K fixed-fee for the build, depending on how many scenarios and how nasty the source systems are. Make.com runs $9 to $300 a month based on operations volume. n8n is $20 a month cloud or self-hosted-free. We don't take a cut. The bill goes to your card."
  },
  {
    q: 'Self-host or cloud?',
    a: "Default is Make.com cloud — it's cheap, fast, and well-supported. We deploy n8n self-hosted when there's a real reason: regulated data, on-prem requirements, or a team that wants the source code in their hands. Self-hosted n8n is a 1.5x build cost and the ops burden is yours. We'll tell you which one you need."
  },
  {
    q: 'We have an old Zapier setup nobody understands. Do we throw it out?',
    a: "Probably not all of it. We do a one-week audit — read every Zap, draw the dependency graph, flag what's load-bearing — and tell you which to keep, which to port, and which to retire. Most clients keep about a third, port a third, and retire a third because nobody actually noticed they were broken. We've billed $5K to save somebody $40K of rebuild work. It happens."
  }
];
---
<Layout
  title={`${title} — Commonwealth AI Partners`}
  description={subhead}
>
  <main>
    {/* HERO */}
    <section class="relative bg-cobalt-500 text-carbon overflow-hidden">
      <div aria-hidden="true" class="absolute inset-y-0 left-1/3 w-px bg-carbon/15 hidden md:block"></div>
      <div aria-hidden="true" class="absolute inset-y-0 left-2/3 w-px bg-carbon/15 hidden md:block"></div>

      <div class="relative container min-h-[80vh] pt-28 md:pt-40 pb-16 grid grid-cols-12 gap-x-4 md:gap-x-6 grid-rows-[auto_1fr_auto]">
        <div class="col-span-12 md:col-start-5 md:col-span-8 grid grid-cols-2 meta-strip">
          <span class="border-t border-carbon/40 pt-4">{kicker}</span>
          <span class="border-t border-carbon/40 pt-4 text-right">{code}</span>
        </div>

        <div class="col-span-12 md:col-span-10 row-start-2 mt-8 md:mt-12 flex flex-col gap-6 md:gap-8">
          <h1 class="font-display text-display-xl tracking-tightest text-balance">{title}</h1>
          <p class="font-display text-2xl md:text-4xl tracking-tight text-carbon/85 max-w-3xl text-balance">{tagline}</p>
        </div>

        <div class="col-span-12 md:col-span-8 row-start-3 mt-10 md:mt-12 flex flex-col gap-7">
          <p class="text-lg md:text-xl text-carbon/85 leading-snug max-w-2xl text-balance text-pretty">{subhead}</p>
          <div class="flex flex-wrap items-center gap-4 md:gap-6">
            <a href="/#contact" class="group inline-flex items-center justify-between gap-6 h-12 sm:h-14 px-5 sm:px-7 bg-carbon text-white hover:bg-carbon-700 font-mono text-[11px] uppercase tracking-[0.16em] transition-colors">
              <span>Book an Orchestration Audit</span>
              <span aria-hidden="true" class="group-hover:translate-x-1 transition-transform">&rarr;</span>
            </a>
            <span class="meta-strip text-white">30 min &middot; Bring your worst copy-paste loop.</span>
          </div>
        </div>
      </div>

      <div class="relative bg-carbon-950 border-y border-cobalt-500/20 py-5 md:py-7 overflow-hidden">
        <div class="container flex flex-wrap items-center gap-x-8 md:gap-x-12 gap-y-4">
          <span class="meta-strip text-cobalt-400 shrink-0">Stack</span>
          {partners.map((p) => (
            <span class="font-display text-lg md:text-xl tracking-tight text-ash-200">{p}</span>
          ))}
        </div>
      </div>
    </section>

    {/* DIAGNOSIS */}
    <section class="relative bg-carbon py-24 md:py-32 border-t border-white/5">
      <div class="container grid grid-cols-12 gap-x-6 gap-y-12">
        <div class="col-span-12 md:col-span-3 meta-strip text-cobalt-400 border-t border-cobalt-500/40 pt-4">Diagnosis</div>
        <div class="col-span-12 md:col-span-9">
          <h2 class="font-display text-display-lg tracking-tightest text-balance">
            You need this if a person is the integration between two systems.
          </h2>
        </div>

        <div class="col-span-12 md:col-span-7 md:col-start-4 mt-2 md:mt-4 space-y-5 text-ash-300 text-base md:text-lg leading-relaxed">
          <p class="text-pretty">
            Ecosystem orchestration means the connective tissue between your tools &mdash; the
            part that turns a new lead in HubSpot into a contact in QuickBooks, a calendar
            invite in Google, a welcome sequence in ActiveCampaign, and a Slack ping to the
            account owner. Built once, runs forever, with logs, retries, and a kill switch.
            We deploy this on Make.com and n8n. We do not sell another Zapier subscription on
            top of yours.
          </p>
          <p class="text-pretty">
            The clients who hire us for this are usually a few SaaS subscriptions past their
            breaking point. They bought the right tools. They just never got the wiring.
            Somebody on the team &mdash; usually the most expensive somebody &mdash; is the
            human bus between them. They cannot go on vacation because the bus stops running.
            Common signs:
          </p>
          <ul class="space-y-3 pt-2">
            {symptoms.map((s) => (
              <li class="grid grid-cols-[1.25rem_1fr] gap-3 items-start">
                <span class="text-cobalt-400 mt-2.5 inline-block w-2 h-2 bg-current"></span>
                <span class="text-pretty">{s}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    {/* DELIVERABLES */}
    <section class="relative bg-carbon-900 py-24 md:py-32 border-t border-white/10">
      <div class="container">
        <div class="grid grid-cols-12 gap-6 mb-12 md:mb-20 items-end">
          <div class="col-span-12 md:col-span-3 meta-strip text-ash-500 border-t border-white/15 pt-4">What you get</div>
          <h2 class="col-span-12 md:col-span-9 font-display text-display-lg tracking-tightest text-balance">
            Six concrete deliverables. No vapor.
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-white/10 border border-white/10">
          {deliverables.map((d) => (
            <article class="bg-carbon-900 p-8 sm:p-10 flex flex-col gap-5">
              <div class="flex items-center justify-between meta-strip">
                <span class="text-cobalt-400">{d.n}</span>
                <span class="text-ash-500">Deliverable</span>
              </div>
              <h3 class="font-display text-2xl md:text-3xl tracking-tight leading-[1.1] text-balance">{d.title}</h3>
              <p class="text-ash-300 leading-relaxed text-pretty">{d.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    {/* ARCHITECTURE */}
    <section class="relative bg-carbon py-24 md:py-32 border-t border-white/10 overflow-hidden">
      <div class="container grid grid-cols-12 gap-x-6 gap-y-12">
        <div class="col-span-12 md:col-span-5 flex flex-col gap-6">
          <div class="meta-strip text-cobalt-400 border-t border-cobalt-500/40 pt-4 max-w-xs">Architecture</div>
          <h2 class="font-display text-display-lg tracking-tightest text-balance text-cobalt-500">One nervous system. Many limbs.</h2>
          <p class="text-ash-300 text-base md:text-lg leading-relaxed text-pretty">
            Hub-and-spoke pattern, run on Make.com or n8n. Inbound events &mdash; a Stripe
            charge, a Calendly booking, a form submit &mdash; land in a single event layer.
            The orchestration engine reads the event, applies your business rules, and fans
            the work out to the right downstream tools.
          </p>
          <p class="text-ash-500 text-sm leading-relaxed text-pretty">
            Observability is the deliverable. Every scenario logs to a dashboard your team
            can read. Errors route to Slack with the offending payload. Retries are
            automatic. The system tells on itself before a customer does.
          </p>
        </div>

        <div class="col-span-12 md:col-span-7">
          <svg viewBox="0 0 800 600" class="w-full h-auto text-cobalt-500/85" aria-hidden="true">
            <g stroke="currentColor" fill="none" stroke-width="1.25" stroke-linecap="square">
              <rect x="40" y="40" width="720" height="520" />
              <line x1="40" y1="80" x2="760" y2="80" stroke-dasharray="3 5" opacity="0.55" />
              <line x1="40" y1="540" x2="760" y2="540" stroke-dasharray="3 5" opacity="0.55" />

              <rect x="80" y="120" width="140" height="50" />
              <rect x="80" y="200" width="140" height="50" />
              <rect x="80" y="280" width="140" height="50" />
              <rect x="80" y="360" width="140" height="50" />
              <rect x="80" y="440" width="140" height="50" />

              <rect x="320" y="180" width="200" height="240" />
              <line x1="320" y1="230" x2="520" y2="230" />
              <line x1="320" y1="320" x2="520" y2="320" />
              <line x1="320" y1="370" x2="520" y2="370" />

              <rect x="600" y="160" width="140" height="50" />
              <rect x="600" y="240" width="140" height="50" />
              <rect x="600" y="320" width="140" height="50" />
              <rect x="600" y="400" width="140" height="50" />

              <path d="M220 145 H270 V200 H320" />
              <path d="M220 225 H280 V230 H320" />
              <path d="M220 305 H320" />
              <path d="M220 385 H280 V370 H320" />
              <path d="M220 465 H280 V410 H320" />

              <path d="M520 200 H560 V185 H600" />
              <path d="M520 270 H560 V265 H600" />
              <path d="M520 350 H560 V345 H600" />
              <path d="M520 400 H560 V425 H600" />
            </g>

            <g font-family="JetBrains Mono, ui-monospace, monospace" font-size="10" fill="currentColor" text-anchor="middle" letter-spacing="0.08em">
              <text x="150" y="148">STRIPE</text>
              <text x="150" y="228">CALENDLY</text>
              <text x="150" y="308">FORMS</text>
              <text x="150" y="388">INBOUND EMAIL</text>
              <text x="150" y="468">VENDOR APIs</text>

              <text x="420" y="220" font-size="11">MAKE.COM / n8n</text>
              <text x="420" y="280" font-size="10">EVENT LAYER</text>
              <text x="420" y="350" font-size="10">CONFLICT RULES</text>
              <text x="420" y="400" font-size="10">RETRIES + LOGS</text>

              <text x="670" y="188">CRM</text>
              <text x="670" y="268">ACCOUNTING</text>
              <text x="670" y="348">EMAIL PLATFORM</text>
              <text x="670" y="428">SLACK ALERTS</text>
            </g>

            <g stroke="currentColor" stroke-width="1" fill="none" opacity="0.7">
              <path d="M30 40 H50 M40 30 V50" />
              <path d="M750 40 H770 M760 30 V50" />
              <path d="M30 560 H50 M40 550 V570" />
              <path d="M750 560 H770 M760 550 V570" />
            </g>
          </svg>

          <div class="mt-6 border border-cobalt-500/40 grid grid-cols-[auto_1fr] divide-y divide-cobalt-500/20 max-w-md">
            <div class="row-span-3 p-4 sm:p-5 border-r border-cobalt-500/40 flex items-center justify-center bg-cobalt-500/5">
              <span class="font-display text-cobalt-500 font-bold text-2xl">{code}</span>
            </div>
            <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-0 text-cobalt-200 meta-strip">
              <div class="col-span-2 p-4 sm:p-5 grid grid-cols-[auto_1fr] gap-x-6 border-b border-cobalt-500/20">
                <dt class="text-cobalt-400">Title</dt>
                <dd>Hub-and-Spoke Event Layer</dd>
              </div>
              <div class="col-span-2 p-4 sm:p-5 grid grid-cols-[auto_1fr] gap-x-6 border-b border-cobalt-500/20">
                <dt class="text-cobalt-400">DWG No.</dt>
                <dd>203.01.00</dd>
              </div>
              <div class="col-span-2 p-4 sm:p-5 grid grid-cols-[auto_1fr] gap-x-6">
                <dt class="text-cobalt-400">Scale</dt>
                <dd>1 / 100</dd>
              </div>
            </dl>
          </div>
        </div>
      </div>
    </section>

    {/* PROCESS */}
    <section class="relative bg-carbon-900 py-24 md:py-32 border-t border-white/10">
      <div class="container">
        <div class="grid grid-cols-12 gap-6 mb-12 md:mb-20 items-end">
          <div class="col-span-12 md:col-span-3 meta-strip text-ash-500 border-t border-white/15 pt-4">Process</div>
          <h2 class="col-span-12 md:col-span-9 font-display text-display-lg tracking-tightest text-balance">
            Six weeks, written down. <span class="text-ash-500">No surprises.</span>
          </h2>
        </div>

        <ol class="border border-white/10 divide-y divide-white/10">
          {process.map((p, i) => (
            <li class="grid grid-cols-1 md:grid-cols-[10rem_1fr_auto] items-start gap-x-6 gap-y-3 p-6 md:p-8 hover:bg-carbon-800 transition-colors">
              <div class="meta-strip text-cobalt-400 pt-1">{p.week}</div>
              <div class="space-y-2">
                <h3 class="font-display text-xl md:text-2xl tracking-tight">{p.label}</h3>
                <p class="text-ash-300 leading-relaxed text-pretty max-w-2xl">{p.body}</p>
              </div>
              <div class="meta-strip text-ash-500 hidden md:block pt-1">{`STEP ${String(i + 1).padStart(2, '0')}`}</div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    {/* CASE STUDIES */}
    <section class="relative bg-carbon py-24 md:py-32 border-t border-white/10">
      <div class="container">
        <div class="grid grid-cols-12 gap-6 mb-12 md:mb-20 items-end">
          <div class="col-span-12 md:col-span-3 meta-strip text-ash-500 border-t border-white/15 pt-4">Receipts</div>
          <h2 class="col-span-12 md:col-span-9 font-display text-display-lg tracking-tightest text-balance">
            Two recent orchestrations. <span class="text-ash-500">Real numbers.</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-white/10 border border-white/10">
          {caseStudies.map((s) => (
            <a href={s.href} class="group bg-carbon p-8 sm:p-10 flex flex-col gap-7 min-h-[360px] hover:bg-carbon-800 transition-colors">
              <div class="flex items-center justify-between meta-strip">
                <span class="text-cobalt-400">{s.code}</span>
                <span class="text-ash-500">{s.sector}</span>
              </div>
              <h3 class="font-display text-2xl md:text-3xl tracking-tight leading-[1.05] text-balance flex-1">{s.title}</h3>
              <div class="flex items-end justify-between gap-4 pt-6 border-t border-white/10">
                <div>
                  <div class="meta-strip text-ash-500 mb-1">Impact</div>
                  <div class="font-display text-cobalt-400 text-base md:text-lg">{s.impact}</div>
                </div>
                <span class="meta-strip text-ash-500 group-hover:text-cobalt-400 transition-colors">Read &rarr;</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* FAQ */}
    <section class="relative bg-carbon-900 py-24 md:py-32 border-t border-white/10">
      <div class="container">
        <div class="grid grid-cols-12 gap-6 mb-12 md:mb-20 items-end">
          <div class="col-span-12 md:col-span-3 meta-strip text-ash-500 border-t border-white/15 pt-4">FAQ</div>
          <h2 class="col-span-12 md:col-span-9 font-display text-display-lg tracking-tightest text-balance">
            The questions you&rsquo;d ask on a call.
          </h2>
        </div>

        <div class="border border-white/10 divide-y divide-white/10">
          {faqs.map((f, i) => (
            <details class="group">
              <summary class="cursor-pointer list-none px-6 md:px-8 py-6 md:py-7 flex items-center justify-between gap-6 hover:bg-carbon-800 transition-colors">
                <span class="font-display text-lg md:text-xl tracking-tight pr-4 text-balance">
                  <span class="meta-strip text-cobalt-400 mr-4 inline-block">{`Q.${String(i + 1).padStart(2, '0')}`}</span>
                  {f.q}
                </span>
                <span aria-hidden="true" class="text-2xl shrink-0 transition-transform group-open:rotate-45 text-cobalt-400">+</span>
              </summary>
              <div class="px-6 md:px-8 pb-7 md:pb-8 -mt-2 max-w-3xl text-ash-300 leading-relaxed text-pretty">{f.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* ENGAGEMENT */}
    <section class="relative bg-carbon py-24 md:py-32 border-t border-white/10">
      <div class="container grid grid-cols-12 gap-x-6 gap-y-10">
        <div class="col-span-12 md:col-span-5">
          <div class="meta-strip text-ash-500 border-t border-white/15 pt-4 max-w-xs mb-6">Engagement</div>
          <h2 class="font-display text-display-lg tracking-tightest text-balance">What working with us looks like.</h2>
        </div>

        <div class="col-span-12 md:col-span-7 grid grid-cols-1 sm:grid-cols-2 gap-px bg-white/10 border border-white/10">
          <div class="bg-carbon p-6 sm:p-8 flex flex-col gap-3">
            <div class="meta-strip text-cobalt-400">Typical scope</div>
            <div class="font-display text-2xl tracking-tight">$20K &ndash; $60K</div>
            <p class="text-ash-400 text-sm leading-relaxed">Fixed-fee build. Eight to twenty-five scenarios depending on stack.</p>
          </div>
          <div class="bg-carbon p-6 sm:p-8 flex flex-col gap-3">
