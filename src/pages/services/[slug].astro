---
import Stub from '@/layouts/Stub.astro';

// All four DEP services now have dedicated pages:
//   DEP.01 → src/pages/services/enterprise-ai-integration.astro
//   DEP.02 → src/pages/services/relational-data-architecture.astro
//   DEP.03 → src/pages/services/ecosystem-orchestration.astro
//   DEP.04 → src/pages/services/financial-operational-automation.astro
// This dynamic route is kept as a safety net for any new services that get
// scaffolded as stubs before getting a full page.
export function getStaticPaths() {
  return [];
}

const { title, code, description } = Astro.props;
---
<Stub kicker="What We Deploy" title={title} code={code} description={description} />
