---
import Stub from '@/layouts/Stub.astro';

// All six IND industries now have dedicated pages:
//   IND.01 → src/pages/industries/professional-services.astro
//   IND.02 → src/pages/industries/government-civic.astro
//   IND.03 → src/pages/industries/home-services.astro
//   IND.04 → src/pages/industries/media-marketing.astro
//   IND.05 → src/pages/industries/events-conferences.astro
//   IND.06 → src/pages/industries/general-operations.astro
// This dynamic route is kept as a safety net for any new industries that get
// scaffolded as stubs before getting a full page.
export function getStaticPaths() {
  return [];
}

const { title, code, description } = Astro.props;
---
<Stub kicker="Industries" title={title} code={code} description={description} />
