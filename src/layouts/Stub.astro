---
import Layout from './Layout.astro';
import Footer from '../components/Footer.astro';

interface Props {
  kicker: string;
  title: string;
  description?: string;
  code?: string;
  pageTitle?: string;
}

const {
  kicker,
  title,
  description = "We're writing this one up. In the meantime, the fastest path is to talk to us — send the messy version of your operation and we'll come back inside two business days with what the system should look like.",
  code,
  pageTitle
} = Astro.props;
---
<Layout
  title={pageTitle || `${title} — Commonwealth AI Partners`}
  description={description}
>
  <main>
    {/* Cobalt hero block */}
    <section class="relative bg-cobalt-500 text-carbon overflow-hidden">
      <div aria-hidden="true" class="absolute inset-y-0 left-1/3 w-px bg-carbon/15 hidden md:block"></div>
      <div aria-hidden="true" class="absolute inset-y-0 left-2/3 w-px bg-carbon/15 hidden md:block"></div>

      <div class="relative container min-h-[70vh] pt-28 md:pt-40 pb-16 grid grid-cols-12 gap-x-4 md:gap-x-6 grid-rows-[auto_1fr_auto]">
        {/* Metadata strip */}
        <div class="col-span-12 md:col-start-5 md:col-span-8 grid grid-cols-2 meta-strip">
          <span class="border-t border-carbon/40 pt-4">{kicker}</span>
          <span class="border-t border-carbon/40 pt-4 text-right">{code || 'In Progress'}</span>
        </div>

        {/* Title */}
        <h1 class="col-span-12 md:col-span-10 row-start-2 mt-8 md:mt-12 font-display text-display-xl tracking-tightest text-balance">
          {title}
        </h1>

        {/* Description + CTA */}
        <div class="col-span-12 md:col-span-8 row-start-3 mt-10 md:mt-12 flex flex-col gap-7">
          <p class="text-lg md:text-xl text-carbon/85 leading-snug max-w-2xl text-balance text-pretty">
            {description}
          </p>
          <div class="flex flex-wrap items-center gap-4 md:gap-6">
            <a
              href="/#contact"
              class="group inline-flex items-center justify-between gap-6 h-12 sm:h-14 px-5 sm:px-7 bg-carbon text-white hover:bg-carbon-700 font-mono text-[11px] uppercase tracking-[0.16em] transition-colors"
            >
              <span>Book a Systems Audit</span>
              <span aria-hidden="true" class="group-hover:translate-x-1 transition-transform">→</span>
            </a>
            <a
              href="/"
              class="font-mono text-[11px] uppercase tracking-[0.16em] text-carbon hover:text-white transition-colors inline-flex items-center gap-2"
            >
              <span aria-hidden="true">←</span>
              Back to home
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* Optional body slot for any future custom content */}
    <slot />
  </main>

  <Footer />
</Layout>
