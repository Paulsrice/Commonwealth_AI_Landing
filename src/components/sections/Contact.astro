---
import Logo from '../Logo.astro';
---
<section id="contact" class="relative bg-cobalt-500 text-carbon overflow-hidden">
  {/* Decorative grid hairlines */}
  <div aria-hidden="true" class="absolute inset-y-0 left-1/3 w-px bg-carbon/15 hidden md:block"></div>
  <div aria-hidden="true" class="absolute inset-y-0 left-2/3 w-px bg-carbon/15 hidden md:block"></div>

  <div class="container py-24 md:py-36 grid grid-cols-12 gap-x-6 gap-y-12">
    <div class="col-span-12 md:col-span-7">
      <div class="meta-strip border-t border-carbon/40 pt-4 mb-8 max-w-xs flex justify-between">
        <span>Contact</span>
        <span>File 99.00</span>
      </div>
      <h2 class="font-display text-display-xl tracking-tightest text-balance">
        Tell us<br/>what&rsquo;s broken.
      </h2>
      <p class="mt-8 max-w-lg text-carbon/80 text-lg leading-snug text-balance">
        Send the messy version. We’ll come back inside two business days with what we think
        the system should look like and what it would take to stand it up.
      </p>
    </div>

    <div class="col-span-12 md:col-start-9 md:col-span-4 flex flex-col gap-6">
      <a
        href="mailto:hello@commonwealthai.partners"
        class="group block bg-carbon text-white p-6 sm:p-8 hover:bg-carbon-700 transition-colors"
      >
        <div class="meta-strip text-cobalt-400 mb-4">Email</div>
        <div class="font-display text-xl md:text-2xl tracking-tight break-all">
          hello@commonwealthai.partners
        </div>
        <div class="mt-6 meta-strip text-ash-400 flex items-center justify-between">
          <span>Direct line</span>
          <span aria-hidden="true" class="group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </a>

      <a
        href="https://cal.com/commonwealthai"
        class="group block border border-carbon/60 p-6 sm:p-8 hover:bg-carbon hover:text-white transition-colors"
      >
        <div class="meta-strip mb-4">Discovery Call</div>
        <div class="font-display text-xl md:text-2xl tracking-tight">
          Book a 30-min standup.
        </div>
        <div class="mt-6 meta-strip flex items-center justify-between opacity-70 group-hover:opacity-100">
          <span>30 minutes &middot; No deck</span>
          <span aria-hidden="true" class="group-hover:translate-x-1 transition-transform">→</span>
        </div>
      </a>
    </div>

    <div class="col-span-12 mt-8 md:mt-16 flex flex-col md:flex-row md:items-end justify-between gap-6">
      <div class="flex items-center gap-3">
        <Logo iconOnly class="w-12 h-auto text-carbon" />
        <div>
          <div class="font-display text-base font-bold tracking-tight">Commonwealth AI Partners</div>
          <div class="meta-strip text-carbon/60 mt-1">Stand it up. Keep it running.</div>
        </div>
      </div>
      <div class="meta-strip text-carbon/70 flex flex-wrap gap-x-8 gap-y-2">
        <span>Richmond, VA</span>
        <span>Remote-first</span>
        <span>Mon&ndash;Fri, 9&ndash;6 ET</span>
      </div>
    </div>
  </div>
</section>
