---
const pillars = [
  {
    number: '01',
    kicker: 'The Meeting',
    title: 'Rhythm.',
    body:
      'Automation isn’t a set-it-and-forget-it magic trick. It needs a pulse. We bring the alignment, leadership, and high-performance ops cadence to keep your systems honest and your team in step.',
    tag: 'Standup. Daily. Disciplined.'
  },
  {
    number: '02',
    kicker: 'The Reputation',
    title: 'Character.',
    body:
      'The market is flooded with grifters and over-promisers. We are the antithesis: empathy for your real pain points, plain language about what is and isn’t possible, and a commitment to actually deliver.',
    tag: 'Standup as in: stand-up.'
  },
  {
    number: '03',
    kicker: 'The Deployment',
    title: 'Execution.',
    body:
      'We don’t write whitepapers. We build. When you need a complex Make.com workflow, an n8n pipeline, or a relational Supabase architecture wired into Claude, we are the ones who actually stand it up and keep it running.',
    tag: 'Stood up. Standing.'
  }
];
---
<section id="approach" class="relative bg-carbon-900 border-t border-white/10 py-24 md:py-36">
  <div class="container">
    <div class="grid grid-cols-12 gap-6 mb-12 md:mb-20 items-end">
      <div class="col-span-12 md:col-span-3 meta-strip text-ash-500 border-t border-white/15 pt-4">
        Approach
      </div>
      <h2 class="col-span-12 md:col-span-9 font-display text-display-lg tracking-tightest text-balance">
        Three constants of a system that actually holds up.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-white/10 border border-white/10">
      {pillars.map((p) => (
        <article class="bg-carbon-900 p-8 sm:p-10 flex flex-col gap-7 min-h-[440px]">
          <div class="flex items-center justify-between meta-strip">
            <span class="text-cobalt-400">{p.number}</span>
            <span class="text-ash-500">{p.kicker}</span>
          </div>
          <h3 class="font-display text-display-md tracking-tightest leading-none">
            {p.title}
          </h3>
          <p class="text-ash-300 leading-relaxed flex-1 text-pretty">{p.body}</p>
          <div class="meta-strip text-ash-500 pt-6 border-t border-white/10">
            &mdash; {p.tag}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
