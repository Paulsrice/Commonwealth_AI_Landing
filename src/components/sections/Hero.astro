---
import Header from '../Header.astro';
import Logo from '../Logo.astro';
---
<section class="relative bg-cobalt-500 text-carbon overflow-hidden">
  <Header variant="light" />

  {/* Decorative vertical grid lines */}
  <div aria-hidden="true" class="absolute inset-y-0 left-1/3 w-px bg-carbon/15 hidden md:block"></div>
  <div aria-hidden="true" class="absolute inset-y-0 left-2/3 w-px bg-carbon/15 hidden md:block"></div>

  <div class="relative container min-h-[92vh] pt-28 md:pt-40 pb-10 grid grid-cols-12 gap-x-4 md:gap-x-6 grid-rows-[auto_1fr_auto]">
    {/* Top metadata strip — spans the right two-thirds */}
    <div class="col-span-12 md:col-start-5 md:col-span-8 grid grid-cols-2 meta-strip">
      <span class="border-t border-carbon/40 pt-4">System</span>
      <span class="border-t border-carbon/40 pt-4 text-right">Est. 2025</span>
    </div>

    {/* Headline */}
    <h1 class="col-span-12 md:col-span-7 row-start-2 mt-8 md:mt-12 font-display text-display-2xl tracking-tightest text-balance">
      Systems<br/>you can<br/>swear by.
    </h1>

    {/* Big icon mark */}
    <div class="col-span-12 md:col-start-9 md:col-span-4 row-start-2 mt-2 md:mt-0 flex md:items-end justify-end">
      <Logo iconOnly class="w-40 sm:w-64 md:w-full h-auto text-carbon" />
    </div>

    {/* Subhead — bottom-left */}
    <p class="col-span-12 md:col-span-6 row-start-3 mt-10 md:mt-12 text-lg md:text-2xl text-carbon/85 leading-snug max-w-xl text-balance">
      Automation with integrity, built for operators who can&rsquo;t afford to fake it.
    </p>
  </div>

  {/* Industrial photo strip below the cobalt block */}
  <div class="relative h-28 md:h-40 bg-carbon-800 overflow-hidden border-t border-carbon">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_rgba(46,91,255,0.18),transparent_60%)]"></div>
    <svg viewBox="0 0 1200 200" preserveAspectRatio="none" class="absolute inset-0 w-full h-full text-ash-500/40">
      <defs>
        <pattern id="hero-strip" width="60" height="200" patternUnits="userSpaceOnUse">
          <path d="M0 0 L60 200" stroke="currentColor" stroke-width="1" fill="none" />
          <path d="M30 0 L90 200" stroke="currentColor" stroke-width="0.5" fill="none" />
        </pattern>
      </defs>
      <rect width="1200" height="200" fill="url(#hero-strip)" />
    </svg>
    <div class="absolute inset-x-0 bottom-0 h-12 bg-gradient-to-b from-transparent to-carbon"></div>
  </div>
</section>
