---
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;
---
<svg
  viewBox="0 0 800 600"
  xmlns="http://www.w3.org/2000/svg"
  class={`w-full h-auto ${className}`}
  aria-hidden="true"
>
  {/* Frame */}
  <g stroke="currentColor" fill="none" stroke-width="1.25" stroke-linecap="square">
    <rect x="40" y="40" width="720" height="520" />
    <line x1="40" y1="80" x2="760" y2="80" stroke-dasharray="3 5" opacity="0.55" />
    <line x1="40" y1="540" x2="760" y2="540" stroke-dasharray="3 5" opacity="0.55" />
    <line x1="80" y1="40" x2="80" y2="560" stroke-dasharray="3 5" opacity="0.4" />
    <line x1="720" y1="40" x2="720" y2="560" stroke-dasharray="3 5" opacity="0.4" />

    {/* Input nodes */}
    <rect x="100" y="120" width="140" height="60" />
    <rect x="100" y="220" width="140" height="60" />
    <rect x="100" y="320" width="140" height="60" />
    <rect x="100" y="420" width="140" height="60" />

    {/* Center processing block */}
    <rect x="340" y="170" width="160" height="240" />
    <line x1="340" y1="220" x2="500" y2="220" />
    <line x1="340" y1="280" x2="500" y2="280" />
    <line x1="340" y1="340" x2="500" y2="340" />

    {/* Output nodes */}
    <rect x="600" y="120" width="140" height="60" />
    <rect x="600" y="220" width="140" height="60" />
    <rect x="600" y="320" width="140" height="60" />
    <rect x="600" y="420" width="140" height="60" />

    {/* Connectors in → core */}
    <path d="M240 150 H290 V200 H340" />
    <path d="M240 250 H310 V250 H340" />
    <path d="M240 350 H290 V330 H340" />
    <path d="M240 450 H310 V390 H340" />

    {/* Connectors core → out */}
    <path d="M500 200 H560 V150 H600" />
    <path d="M500 260 H560 V250 H600" />
    <path d="M500 320 H560 V350 H600" />
    <path d="M500 380 H560 V450 H600" />
  </g>

  {/* Labels */}
  <g
    font-family="JetBrains Mono, ui-monospace, monospace"
    font-size="10"
    fill="currentColor"
    text-anchor="middle"
    letter-spacing="0.08em"
  >
    <text x="170" y="156">INTAKE</text>
    <text x="170" y="256">CRM</text>
    <text x="170" y="356">DOCS</text>
    <text x="170" y="456">SHEETS</text>

    <text x="420" y="200" font-size="11">CORE</text>
    <text x="420" y="260" font-size="11">RULES</text>
    <text x="420" y="320" font-size="11">QA</text>
    <text x="420" y="380" font-size="11">LOGS</text>

    <text x="670" y="156">SLACK</text>
    <text x="670" y="256">EMAIL</text>
    <text x="670" y="356">LEDGER</text>
    <text x="670" y="456">REPORT</text>
  </g>

  {/* Corner crosshair markers (architectural drawing motif) */}
  <g stroke="currentColor" stroke-width="1" fill="none" opacity="0.7">
    <path d="M30 40 H50 M40 30 V50" />
    <path d="M750 40 H770 M760 30 V50" />
    <path d="M30 560 H50 M40 550 V570" />
    <path d="M750 560 H770 M760 550 V570" />
  </g>
</svg>
