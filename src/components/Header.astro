---
import Logo from './Logo.astro';

interface Props {
  /** 'light' = header sits on a bright/cobalt background and uses dark UI; 'dark' = on dark/black bg, uses light UI. */
  variant?: 'dark' | 'light';
}
const { variant = 'light' } = Astro.props;
const isLight = variant === 'light';
---
<header class:list={[
  'absolute top-0 inset-x-0 z-50 px-5 md:px-8 pt-5 md:pt-7',
  isLight ? 'text-carbon' : 'text-white'
]}>
  <div class="flex items-start justify-between gap-3">
    <a href="/" class="flex items-center gap-2.5 group">
      <Logo class="h-7 sm:h-8 w-auto" />
      <span class="font-display text-base sm:text-lg font-bold tracking-tight leading-none">
        Commonwealth AI<span class={isLight ? 'text-carbon' : 'text-cobalt-400'}>.</span>
      </span>
    </a>

    <nav class="flex items-stretch gap-2" aria-label="Primary">
      <button
        type="button"
        data-open-menu
        aria-label="Open menu"
        aria-controls="site-menu"
        class:list={[
          'group inline-flex items-center justify-between gap-5 h-11 sm:h-14 px-4 sm:px-6 font-mono text-[11px] uppercase tracking-[0.16em] border transition-colors',
          isLight
            ? 'border-carbon/60 hover:bg-carbon hover:text-white'
            : 'border-white/40 hover:bg-white hover:text-carbon'
        ]}
      >
        <span>Menu</span>
        <span class="grid gap-[5px]" aria-hidden="true">
          <span class="block w-5 h-px bg-current"></span>
          <span class="block w-5 h-px bg-current"></span>
        </span>
      </button>
      <a
        href="#contact"
        class:list={[
          'inline-flex items-center justify-between gap-5 h-11 sm:h-14 px-4 sm:px-6 font-mono text-[11px] uppercase tracking-[0.16em] transition-colors',
          isLight
            ? 'bg-carbon text-white hover:bg-carbon-700'
            : 'bg-white text-carbon hover:bg-ash-200'
        ]}
      >
        <span>Contact</span>
        <span aria-hidden="true">→</span>
      </a>
    </nav>
  </div>
</header>
