---
import Logo from './Logo.astro';

// Persistent cobalt top bar. Always visible across the site.
// On ad landing pages where this should be hidden, pass `showHeader={false}`
// to <Layout>.
---
<header class="fixed top-0 inset-x-0 z-50 bg-cobalt-500 text-carbon">
  <div class="px-5 md:px-8 py-4 md:py-5 flex items-start justify-between gap-3">
    <a href="/" class="flex items-center gap-2.5 group">
      <Logo class="h-7 sm:h-8 w-auto" />
      <span class="font-display text-base sm:text-lg font-bold tracking-tight leading-none">
        Commonwealth AI<span class="text-carbon">.</span>
      </span>
    </a>

    <nav class="flex items-stretch gap-2" aria-label="Primary">
      <button
        type="button"
        data-open-menu
        aria-label="Open menu"
        aria-controls="site-menu"
        class="group inline-flex items-center justify-between gap-5 h-11 sm:h-14 px-4 sm:px-6 font-mono text-[11px] uppercase tracking-[0.16em] border border-carbon/60 hover:bg-carbon hover:text-white transition-colors"
      >
        <span>Menu</span>
        <span class="grid gap-[5px]" aria-hidden="true">
          <span class="block w-5 h-px bg-current"></span>
          <span class="block w-5 h-px bg-current"></span>
        </span>
      </button>
      <a
        href="/#contact"
        class="inline-flex items-center justify-between gap-5 h-11 sm:h-14 px-4 sm:px-6 font-mono text-[11px] uppercase tracking-[0.16em] bg-carbon text-white hover:bg-carbon-700 transition-colors"
      >
        <span>Contact</span>
        <span aria-hidden="true">→</span>
      </a>
    </nav>
  </div>
</header>
