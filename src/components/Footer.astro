---
import Logo from './Logo.astro';

const year = new Date().getFullYear();

const cols = [
  {
    label: 'What We Deploy',
    links: [
      { label: 'Enterprise AI Integration', href: '/services/enterprise-ai-integration' },
      { label: 'Relational Data Architecture', href: '/services/relational-data-architecture' },
      { label: 'Ecosystem Orchestration', href: '/services/ecosystem-orchestration' },
      { label: 'Financial & Ops Automation', href: '/services/financial-operational-automation' }
    ]
  },
  {
    label: 'Industries',
    links: [
      { label: 'Professional Services', href: '/industries/professional-services' },
      { label: 'Real Estate & Construction', href: '/industries/real-estate-construction' }
    ]
  },
  {
    label: 'Philosophy',
    links: [
      { label: 'Rhythm', href: '#philosophy' },
      { label: 'Character', href: '#philosophy' },
      { label: 'Execution', href: '#philosophy' }
    ]
  },
  {
    label: 'Company',
    links: [
      { label: 'Case Studies', href: '/case-studies' },
      { label: 'Contact', href: '#contact' },
      { label: 'LinkedIn', href: 'https://linkedin.com', external: true }
    ]
  }
];
---
<footer class="relative bg-carbon-950 border-t border-white/10 text-ash-300">
  <div class="container py-16 md:py-24">
    <div class="grid gap-12 md:gap-16 md:grid-cols-[1.4fr_repeat(4,minmax(0,1fr))]">
      <div>
        <a href="/" class="inline-flex items-center gap-2.5">
          <Logo class="h-9 w-auto text-white" />
          <span class="font-display text-xl font-bold tracking-tight text-white leading-none">
            Commonwealth AI<span class="text-cobalt-400">.</span>
          </span>
        </a>
        <p class="mt-6 max-w-sm text-ash-400 text-sm leading-relaxed">
          A standup AI &amp; automation partner for operators who can&rsquo;t afford to fake it.
          We build the systems. Then we keep them running.
        </p>
        <div class="mt-8 meta-strip text-ash-500 flex items-center gap-3">
          <span>Est. 2025</span>
          <span class="h-px w-10 bg-current/40"></span>
          <span>Norfolk, VA &middot; Remote</span>
        </div>
      </div>

      {cols.map((col) => (
        <div>
          <div class="meta-strip text-ash-500 mb-5">{col.label}</div>
          <ul class="space-y-3 text-sm">
            {col.links.map((l) => (
              <li>
                <a
                  href={l.href}
                  class="text-ash-200 hover:text-white transition-colors inline-flex items-center gap-2"
                  rel={l.external ? 'noopener noreferrer' : undefined}
                  target={l.external ? '_blank' : undefined}
                >
                  {l.label}
                  {l.external && <span aria-hidden="true" class="text-cobalt-400">↗</span>}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-16 pt-8 border-t border-white/10 flex flex-col md:flex-row gap-4 md:items-center md:justify-between">
      <div class="meta-strip text-ash-500">
        © {year} Commonwealth AI Partners, LLC. All rights reserved.
      </div>
      <div class="meta-strip text-ash-500 flex flex-wrap gap-x-6 gap-y-2">
        <a href="/privacy" class="hover:text-white transition-colors">Privacy</a>
        <a href="/terms" class="hover:text-white transition-colors">Terms</a>
        <a href="mailto:hello@commonwealthai.partners" class="hover:text-white transition-colors">hello@commonwealthai.partners</a>
      </div>
    </div>
  </div>
</footer>
